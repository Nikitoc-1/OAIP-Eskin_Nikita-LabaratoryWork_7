<Window x:Class="Laba_7_Eskin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лабораторная работа №7 - Все фигуры" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="5" HorizontalAlignment="Center">
            <Button x:Name="BtnRectangle" Content="Прямоугольник" Width="40" Height="30" Margin="3"  Click="BtnRectangle_Click"/>
            <Button x:Name="BtnSquare" Content="Квадрат" Width="40" Height="30" Margin="3"  Click="BtnSquare_Click"/>
            <Button x:Name="BtnEllipse" Content="Эллипс" Width="50" Height="30" Margin="3"  Click="BtnEllipse_Click"/>
            <Button x:Name="BtnCircle" Content="Окружность" Width="50" Height="30" Margin="3"  Click="BtnCircle_Click"/>
            <Button x:Name="BtnTriangle" Content="Треугольник" Width="50" Height="30" Margin="3"  Click="BtnTriangle_Click"/>
            <Button x:Name="BtnRocket" Content="Ракета" Width="50" Height="30" Margin="3"  Click="BtnRocket_Click"/>
            <Button x:Name="BtnClear" Content="Очистить" Width="30" Height="30" Margin="3"  Click="BtnClear_Click"/>
            <Label Content="Высота:"/>
            <TextBox x:Name ="RHeight" Width="30" Height="30" Margin="3"/>
            <Label Content="Ширина:"/>
            <TextBox x:Name="RWidth" Width="30" Height="30" Margin="3"/>
            <Label Content="Радиус:"/>
            <TextBox x:Name ="RRadius" Width="30" Height="30" Margin="3"/>
            <Button x:Name="BtnApplyRec" Content="Принять размеры прямоугольника" Width="60" Height="30" Margin="3" Click="BtnApplyRec_Click"/>
            <Button x:Name="BtnApplyCir" Content="Принять размеры окружности" Width="60" Height="30" Margin="3" Click="BtnApplyCir_Click"/>
            <Label Content="Количество углов" Width="30" Height="30" Margin="3"/>
            <TextBox x:Name="CountAngle" Width="20" Height="30" Margin="3"/>
            <Button x:Name="BtnPolygon" Content="Многоугольник" Width="50" Height="30" Margin="3" Click="BtnPolygon_Click"/>
        </WrapPanel>

        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="2" Margin="5" Background="White">
            <Image x:Name="DrawingImage" 
                   Stretch="Uniform"
                   MouseLeftButtonDown="DrawingImage_MouseLeftButtonDown"
                   MouseMove="DrawingImage_MouseMove"
                   MouseLeftButtonUp="DrawingImage_MouseLeftButtonUp"
                   MouseRightButtonDown="DrawingImage_MouseRightButtonDown"/>
        </Border>
    </Grid>
</Window>